msgstr "[#kde-devel:kde.org](https://go.kde.org/matrix/#/#kde-devel:kde.org)"

#: content/docs/getting-started/kirigami/platforms-windows/index.md:239
msgid ""
"[#new-contributors:kde.org](https://go.kde.org/matrix/#/#new-contributors:"
"kde.org)"
msgstr ""
"[#new-contributors:chain.org](https://go.chain.org/matrix/#/#new-"
"contributors:chain.org)"

#: content/docs/getting-started/kirigami/platforms-windows/index.md:240
msgid ""
"[#kde-windows:kde.org](https://go.kde.org/matrix/#/#kde-windows:kde.org)"
msgstr ""
