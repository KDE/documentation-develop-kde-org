msgstr "تعلّم كيفية تطوير برمجيات كيدي"

#. develop.menu.api.description
#: i18n/en.yaml:146
msgid "Read API docs for KDE's development libraries"
msgstr "اقرأ وثائق واجهة برمجة التطبيقات لمكتبات تطوير كيدي"

#. develop.menu.distribute
#: i18n/en.yaml:148
msgid "Distribute"
msgstr "وزع"

#. develop.menu.distribute.description
#: i18n/en.yaml:150
msgid "Get your KDE app in front of users"
msgstr "اعرض تطبيق كيدي الخاص بك أمام المستخدمين"
