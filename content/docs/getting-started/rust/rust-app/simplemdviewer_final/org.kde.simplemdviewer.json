{
  "id": "org.kde.simplemdviewer",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.9",
  "sdk": "org.kde.Sdk",
  "command": "simplemdviewer",
  "desktop-file-name-suffix": " (Nightly)",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin"
  },
  "finish-args": [
    "--share=ipc",
    "--device=dri",
    "--socket=fallback-x11",
    "--socket=wayland"
  ],
  "modules": [
    {
      "buildsystem": "cmake",
      "name": "corrosion",
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/corrosion-rs/corrosion.git",
          "tag": "v0.6.1"
        }
      ]
    },
    {
      "buildsystem": "cmake",
      "name": "simplemdviewer",
      "sources": [
        "cargo-sources.json",
        {
          "type": "dir",
          "path": "."
        },
        {
          "type": "shell",
          "commands": [
            "mkdir -p .cargo",
            "cp -vf cargo/config .cargo/config.toml"
          ]
        }
      ]
    }
  ]
}
